{
  "name": "willdressed-shop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5173",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "node prisma/ensure-sqlite-file.js && prisma migrate deploy",
    "prisma:migrate": "node prisma/ensure-sqlite-file.js && prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "express": "^4.18.3",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "prisma": "^7.8.0",
    "vite": "^5.4.11"
  }
}
