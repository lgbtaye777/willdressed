{
  "output": {
    "filePath": "repomix-output.xml",
    "style": "xml",
    "removeComments": false,
    "removeEmptyLines": false
  },
  "ignore": {
    "useGitignore": true,
    "useDefaultPatterns": true,
    "customPatterns": [
      "repomix-output.*",
      "*.repomix.*",
      "node_modules/**",
      "dist/**",
      "build/**",
      ".vite/**",
      ".cache/**",
      ".env",
      ".env.*",
      "!.env.example",
      "prisma/dev.db",
      "*.db",
      "*.db-journal",
      "*.sqlite",
      "*.sqlite3",
      "junk/**",
      "public — копия/**",
      "public - копия/**",
      "public copy/**",
      "backup/**",
      "backups/**",
      "screenshots/**",
      "design/**",
      "public/videos/**",
      "public/models/**",
      "public/**/*.mp4",
      "public/**/*.mov",
      "public/**/*.webm",
      "public/**/*.glb",
      "public/**/*.gltf",
      "public/**/*.bin",
      "public/**/*.png",
      "public/**/*.jpg",
      "public/**/*.jpeg",
      "public/**/*.webp"
    ]
  }
}
